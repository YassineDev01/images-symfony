{% extends 'base.html.twig' %}

{% block title %}Product index{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Products</h1>
        <a class="btn btn-primary" href="{{ path('app_product_new') }}"> <span class="fs-5">+ </span>Create new</a>
    </div>
        <div class="alert alert-info">
            Nombre de produits :<span class="fs-5" > {{ products|length }} </span>
        </div>


    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Description</th>
                <th>Is_active</th>
                <th>Stock</th>
                <th>category</th>
                <th>Images
            </tr>
        </thead>
        <tbody>
        {% for product in products %}
            <tr>
                <td>{{ product.id }}</td>
                <td>{{ product.name }}</td>
                <td>{{ product.description }}</td>
                <td>{{ product.isActive ? 'Yes' : 'No' }}</td>
                <td>{{ product.stock ? 'Yes' : 'No' }}</td>
                <td>
                    {% if product.category %}
                        {{ product.category.nameCategory }}
                    {% else %}
                        -
                    {% endif %}
                </td>
                <td>
                    {% for image in product.productImages %}
                        {% if image.imageName %}
                            <img src="{{ asset('uploads/products/' ~ image.imageName) }}"
                                width="80"
                        {% else %}
                            <span class="text-muted">No image</span>
                        {% endif %}      
                    {% endfor %}
                </td>

                <td align="right">
                    <a class="btn btn-secondary" href="{{ path('app_product_show', {'id': product.id}) }}">show</a>
                    <a class="btn btn-warning" href="{{ path('app_product_edit', {'id': product.id}) }}">edit</a>
                    <a class="btn btn-danger" href="{{ path('app_product_delete', {'id': product.id}) }}"
                       onclick="return confirm('Are you sure you want to delete this item?');">
                        delete
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

   
{% endblock %}
