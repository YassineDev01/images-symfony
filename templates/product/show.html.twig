{% extends 'base.html.twig' %}

{% block title %}Product{% endblock %}

{% block body %}
<div class="container py-5">

    <!-- Title -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Product Details</h1>
        <a class="btn btn-outline-secondary" href="{{ path('app_product_index') }}">
            ← Back to list
        </a>
    </div>

    <!-- Images Section -->
    {% if product.productImages|length > 0 %}
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Images</h5>

                <div class="row g-3">
                    {% for image in product.productImages %}
                        <div class="col-6 col-md-3">
                            <img src="{{ vich_uploader_asset(image, 'imageFile') }}"
                                 class="img-fluid rounded shadow-sm"
                                 style="height:200px; object-fit:cover;">
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    <!-- Product Info -->
    <div class="card shadow-sm">
        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-3 fw-semibold">ID</div>
                <div class="col-md-9">{{ product.id }}</div>
            </div>

            <hr>

            <div class="row mb-3">
                <div class="col-md-3 fw-semibold">Name</div>
                <div class="col-md-9">{{ product.name }}</div>
            </div>

            <hr>

            <div class="row mb-3">
                <div class="col-md-3 fw-semibold">Description</div>
                <div class="col-md-9 text-muted">
                    {{ product.description }}
                </div>
            </div>

            <hr>

            <div class="row mb-3">
                <div class="col-md-3 fw-semibold">Active</div>
                <div class="col-md-9">
                    {% if product.isActive %}
                        <span class="badge bg-success">Yes</span>
                    {% else %}
                        <span class="badge bg-danger">No</span>
                    {% endif %}
                </div>
            </div>

            <hr>

            <div class="row">
                <div class="col-md-3 fw-semibold">Stock</div>
                <div class="col-md-9">
                    <span class="badge bg-primary">
                        {{ product.stock }}
                    </span>
                </div>
            </div>

        </div>
    </div>

    <!-- Buttons -->
    <div class="mt-4 d-flex gap-2">
        <a class="btn btn-warning" href="{{ path('app_product_edit', {'id': product.id}) }}">
            ✏️ Edit
        </a>

        {{ include('product/_delete_form.html.twig') }}
    </div>

</div>
{% endblock %}